# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (optional; for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps (optional; for map and bubbles)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Cloudinary (optional; for Wander Moments)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini (optional; for intent parsing in Create Bubble)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ML recommendations (optional; FastAPI service URL)
RECOMMENDATIONS_API_URL=

# Dev only (optional; allow moment upload without auth)
# ALLOW_UPLOAD_WITHOUT_AUTH=true
